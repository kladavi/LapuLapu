anulife.com" rel=3D"nofollow"><strong>mlj_it_is_support@manulife.com</stron=
g></a><strong> if you have done</strong><em><strong> Change the password im=
mediately</strong></em></p></li>
<li local-id=3D"11162cfb-671f-4e00-8a4a-16e7f28d3a65">
<p local-id=3D"e64ad8f093ff">System queue? <strong>N/A</strong></p></li>
</ul></li>
</ul>
<hr local-id=3D"439d954f-e9bb-4d7b-9058-47cf281ab2e1">
<h3 local-id=3D"a42916f0e4c2" id=3D"INC08672078-mfcgd\wasAPIMprodcredential=
expiry-D.Escalation/enforcement">D. Escalation / enforcement</h3>
<ul local-id=3D"4ff70fee-4877-4eef-96f8-810bd4045fa7">
<li local-id=3D"d80a6c9e-8119-413b-9242-a2e26e0a96e5">
<p local-id=3D"12f4018bfa18">If password is not rotated:</p>
<ul local-id=3D"79a37586-e3fc-4811-9441-0cf95a2dd2fc">
<li local-id=3D"7d82bd0b-c2b8-449e-91fe-3bb508e033dc">
<p local-id=3D"4b46d4137a65">Is there escalation? <strong>Global Access Man=
agement Team (</strong><a class=3D"external-link" href=3D"mailto:Informatio=
n_Security@manulife.com" rel=3D"nofollow"><strong>Information_Security@manu=
life.com</strong></a><strong>) should notify you before the password expire=
s</strong></p></li>
<li local-id=3D"a6c25f8c-354f-464d-b766-81ec6b9542a0">
<p local-id=3D"49cdd9465570">Is account locked automatically? <strong>You c=
an ask Global Access Management Team (</strong><a class=3D"external-link" h=
ref=3D"mailto:Information_Security@manulife.com" rel=3D"nofollow"><strong>I=
nformation_Security@manulife.com</strong></a><strong>) about this</strong><=
/p></li>
</ul></li>
</ul>
<hr local-id=3D"2ca7d4f2-83a3-43f3-a35e-421dee1ffd33">
<h3 local-id=3D"1f2fad431bdd" id=3D"INC08672078-mfcgd\wasAPIMprodcredential=
